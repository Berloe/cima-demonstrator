# CIMA Demonstrator — environment configuration
# Copy this file to .env and fill in your values.
# The demonstrator reads CIMA_DEMO_* variables (or .env file via pydantic-settings).

# ── Required ──────────────────────────────────────────────────────────────────

# OpenAI API key (required when using the openai LLM provider)
CIMA_DEMO_OPENAI_API_KEY=sk-...

# ── Runtime mode (default: standalone) ───────────────────────────────────────
# standalone  — in-memory stores, no external services required (default)
# full        — PostgreSQL + Qdrant + TEI backed runtime
CIMA_DEMO_RUNTIME_MODE=standalone

# ── LLM backend ───────────────────────────────────────────────────────────────
# openai      — hosted OpenAI API (gpt-4o, gpt-4o-mini, etc.)
# llamacpp    — local OpenAI-compatible llama.cpp server
CIMA_DEMO_LLM_PROVIDER=openai
CIMA_DEMO_LLM_MODEL=gpt-4o
CIMA_DEMO_LLM_TEMPERATURE=0
CIMA_DEMO_LLM_MAX_TOKENS=512
CIMA_DEMO_LLM_TIMEOUT=300

# ── Server ────────────────────────────────────────────────────────────────────
CIMA_DEMO_PORT=8000

# ── Local llama.cpp (only needed when LLM_PROVIDER=llamacpp) ─────────────────
# CIMA_DEMO_LLM_URL=http://localhost:8080
# CIMA_DEMO_LLM_MODEL=mistral
# CIMA_DEMO_STANDALONE_LLM_BACKEND=llamacpp
# CIMA_DEMO_LLM_TIMEOUT=3600
